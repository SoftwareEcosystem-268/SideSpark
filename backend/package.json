{
  "name": "backend",
  "version": "1.0.0",
  "description": "SideSpark backend API with Express and Prisma",
  "main": "dist/index.js",
  "packageManager": "pnpm@8.15.0",
  "engines": {
    "node": ">=18.18.0"
  },
  "scripts": {
    "dev": "node scripts/prisma-generate.cjs && ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "node scripts/prisma-generate.cjs && tsc",
    "start": "node dist/index.js",
    "test": "node scripts/prisma-generate.cjs && node scripts/prepare-test-db.cjs && vitest",
    "test:run": "node scripts/prisma-generate.cjs && node scripts/prepare-test-db.cjs && vitest --run",
    "test:watch": "node scripts/prisma-generate.cjs && node scripts/prepare-test-db.cjs && vitest",
    "test:coverage": "node scripts/prisma-generate.cjs && node scripts/prepare-test-db.cjs && vitest --coverage",
    "test:ui": "node scripts/prisma-generate.cjs && node scripts/prepare-test-db.cjs && vitest --ui",
    "prisma:generate": "node scripts/prisma-generate.cjs",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "prisma:seed": "node scripts/prisma-generate.cjs && ts-node src/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.0.1",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "express-async-errors": "^3.1.1",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "nodemailer": "^8.0.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/morgan": "^1.9.9",
    "@types/node": "^22.9.0",
    "@types/nodemailer": "^7.0.11",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.1.2",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "prisma": "^6.0.1",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.6.3",
    "vitest": "^4.1.1"
  }
}
