generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// User model
model User {
  id            String         @id @default(cuid())
  username      String         @unique
  email         String         @unique
  name          String?
  password      String?
  skills        UserSkill[]
  projects      Project[]
  transactions  Transaction[]
  milestones    Milestone[]
  refreshTokens RefreshToken[]
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")

  @@map("users")
}

// Skill model
model Skill {
  id         String      @id @default(cuid())
  name       String      @unique
  nameEn     String?     @map("name_en")
  category   String?     // creative, tech, business, education, language
  userSkills UserSkill[]

  @@map("skills")
}

// UserSkill junction table (Many-to-Many)
model UserSkill {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  skillId   String   @map("skill_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  skill     Skill    @relation(fields: [skillId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([userId, skillId])
  @@map("user_skills")
}

// Side Hustle Ideas (predefined suggestions)
model Idea {
  id                 String   @id @default(cuid())
  title              String
  description        String
  skills             String[] // Array of skill names
  difficulty         String   // easy, medium, hard
  estimatedIncomeMin Int      @map("estimated_income_min")
  estimatedIncomeMax Int      @map("estimated_income_max")
  incomeUnit         String   @default("THB") @map("income_unit")
  timeToStart        String   @map("time_to_start")
  requiredTools      String[] @map("required_tools")
  resources          String[] // URLs
  steps              String[] // Array of steps to start

  @@map("ideas")
}

// Project model
model Project {
  id           String        @id @default(cuid())
  userId       String        @map("user_id")
  name         String
  description  String?
  initialCost  Int           @default(0) @map("initial_cost")
  monthlyGoal  Int           @default(0) @map("monthly_goal")
  status       String        @default("active") // active, paused, completed
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks        Task[]
  transactions Transaction[]

  @@map("projects")
}

// Task/ToDo model for project planning
model Task {
  id        String   @id @default(cuid())
  projectId String   @map("project_id")
  text      String
  completed Boolean  @default(false)
  order     Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("tasks")
}

// Transaction model (income/expense tracking)
model Transaction {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  projectId   String?  @map("project_id")
  type        String   // income, expense
  amount      Int
  description String?
  date        DateTime @default(now())
  createdAt   DateTime @default(now()) @map("created_at")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project     Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@map("transactions")
}

// Milestone model
model Milestone {
  id          String    @id @default(cuid())
  userId      String    @map("user_id")
  title       String
  description String?
  target      String    // e.g., "earn 50000", "complete 10 projects"
  achieved    Boolean   @default(false)
  achievedAt  DateTime? @map("achieved_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("milestones")
}

// RefreshToken model for JWT refresh tokens
model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String   @map("user_id")
  expiresAt DateTime @map("expires_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at")

  @@map("refresh_tokens")
}
