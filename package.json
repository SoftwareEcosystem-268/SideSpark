{
  "name": "sidespark",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"pnpm --filter frontend dev\" \"pnpm --filter backend dev\"",
    "build": "pnpm --filter frontend build && pnpm --filter backend build",
    "start": "concurrently \"pnpm --filter frontend start\" \"pnpm --filter backend start\"",
    "lint": "pnpm --filter frontend lint && pnpm --filter backend lint",
    "prisma:generate": "pnpm --filter backend prisma generate",
    "prisma:migrate": "pnpm --filter backend prisma migrate dev",
    "prisma:studio": "pnpm --filter backend prisma studio"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@vitest/ui": "^4.1.1",
    "concurrently": "^8.2.2",
    "vitest": "^4.1.1"
  },
  "packageManager": "pnpm@8.15.0"
}
